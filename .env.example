# ─── Security ────────────────────────────────────────────────────────────────
# Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://your-app-domain.vercel.app"

# ─── Database ────────────────────────────────────────────────────────────────
# Use "firebase" for production (this enables Firestore)
DB_PROVIDER="firebase"

# For SQLite (optional - not recommended for Vercel)
# DATABASE_URL="postgresql://user:password@host:port/database"

# ─── Firebase (Public) ───────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=""

# ─── Firebase (Private/Server-side) ──────────────────────────────────────────
# IMPORTANT: Generate a Private Key JSON from your Firebase Console.
# Paste the ENTIRE contents of the JSON file as a single line string here.
FIREBASE_SERVICE_ACCOUNT_JSON=""

# ─── Optional ────────────────────────────────────────────────────────────────
# For Resend (if using this provider)
# RESEND_API_KEY=""
